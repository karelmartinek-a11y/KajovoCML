{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:kcml:schema:mcp-manifest:1.5",
  "title": "KCML MCP onboarding manifest 1.5",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion", "registrationRevision", "environment", "handlerKey", "handlerVersion",
    "displayName", "businessPurpose", "owners", "contacts", "criticality", "review", "source",
    "runtime", "tool", "contractDigests", "behavior", "testContract", "protocol", "dependencies",
    "dataGovernance", "monitoringProfile", "maintenance", "autoQuarantine", "errorCatalog",
    "evidence", "approvals", "change"
  ],
  "$defs": {
    "sha256": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" },
    "evidenceRef": { "type": "string", "pattern": "^evidence/[A-Za-z0-9][A-Za-z0-9_./-]{1,240}$" },
    "owner": { "type": "string", "minLength": 2, "maxLength": 160 },
    "timestamp": { "type": "string", "format": "date-time" },
    "errorEntry": {
      "type": "object",
      "additionalProperties": false,
      "required": ["code", "description", "classification", "retryable"],
      "properties": {
        "code": { "type": "string", "pattern": "^[A-Z][A-Z0-9_]{1,119}$" },
        "description": { "type": "string", "minLength": 5, "maxLength": 500 },
        "classification": { "enum": ["VALIDATION", "AUTHORIZATION", "DEPENDENCY", "TIMEOUT", "CONFLICT", "INTERNAL"] },
        "retryable": { "const": false }
      }
    },
    "approval": {
      "type": "object",
      "additionalProperties": false,
      "required": ["approver", "approvedAt", "evidenceRef"],
      "properties": {
        "approver": { "$ref": "#/$defs/owner" },
        "approvedAt": { "$ref": "#/$defs/timestamp" },
        "evidenceRef": { "$ref": "#/$defs/evidenceRef" }
      }
    }
  },
  "properties": {
    "schemaVersion": { "const": "1.5" },
    "registrationRevision": { "type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{2,79}$" },
    "environment": { "enum": ["production", "staging"] },
    "handlerKey": { "type": "string", "pattern": "^[a-z0-9][a-z0-9_-]{1,62}$" },
    "handlerVersion": { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+(?:-[A-Za-z0-9.-]+)?$" },
    "displayName": { "type": "string", "minLength": 3, "maxLength": 120 },
    "businessPurpose": { "type": "string", "minLength": 20, "maxLength": 2000 },
    "owners": {
      "type": "object", "additionalProperties": false,
      "required": ["service", "technical", "security", "operations"],
      "properties": {
        "service": { "$ref": "#/$defs/owner" }, "technical": { "$ref": "#/$defs/owner" },
        "security": { "$ref": "#/$defs/owner" }, "operations": { "$ref": "#/$defs/owner" }
      }
    },
    "contacts": {
      "type": "object", "additionalProperties": false,
      "required": ["serviceEmail", "technicalEmail", "securityEmail", "operationsOnCall"],
      "properties": {
        "serviceEmail": { "type": "string", "format": "email", "maxLength": 254 },
        "technicalEmail": { "type": "string", "format": "email", "maxLength": 254 },
        "securityEmail": { "type": "string", "format": "email", "maxLength": 254 },
        "operationsOnCall": { "type": "string", "minLength": 5, "maxLength": 300 }
      }
    },
    "criticality": { "enum": ["LOW", "MEDIUM", "HIGH", "CRITICAL"] },
    "review": {
      "type": "object", "additionalProperties": false,
      "required": ["intervalDays", "approvedAt", "reviewDueAt"],
      "properties": {
        "intervalDays": { "type": "integer", "minimum": 1, "maximum": 365 },
        "approvedAt": { "$ref": "#/$defs/timestamp" }, "reviewDueAt": { "$ref": "#/$defs/timestamp" }
      }
    },
    "source": {
      "type": "object", "additionalProperties": false,
      "required": ["runtime", "entrypoint", "testCommand"],
      "properties": {
        "runtime": { "const": "nodejs24-typescript" }, "entrypoint": { "const": "src/index.ts" },
        "testCommand": { "const": "pnpm test" }
      }
    },
    "runtime": {
      "type": "object", "additionalProperties": false,
      "required": ["memoryMb", "cpuCores", "pidsLimit", "egressAllowlist"],
      "properties": {
        "memoryMb": { "type": "integer", "minimum": 64, "maximum": 512 },
        "cpuCores": { "type": "number", "minimum": 0.1, "maximum": 2 },
        "pidsLimit": { "type": "integer", "minimum": 16, "maximum": 256 },
        "egressAllowlist": { "type": "array", "maxItems": 20, "items": { "type": "string", "pattern": "^[A-Za-z0-9.-]+(?::\\d+)?$" } }
      }
    },
    "tool": {
      "type": "object", "additionalProperties": false,
      "required": ["title", "description", "inputSchema", "outputSchema", "annotations"],
      "properties": {
        "title": { "type": "string", "minLength": 3, "maxLength": 120 },
        "description": { "type": "string", "minLength": 20, "maxLength": 2000 },
        "inputSchema": { "type": "object" }, "outputSchema": { "type": "object" },
        "annotations": {
          "type": "object", "additionalProperties": false,
          "required": ["readOnlyHint", "destructiveHint", "idempotentHint", "openWorldHint", "taskSupport"],
          "properties": {
            "readOnlyHint": { "type": "boolean" }, "destructiveHint": { "type": "boolean" },
            "idempotentHint": { "type": "boolean" }, "openWorldHint": { "type": "boolean" },
            "taskSupport": { "const": "forbidden" }
          }
        }
      }
    },
    "contractDigests": {
      "type": "object", "additionalProperties": false,
      "required": ["inputSchema", "outputSchema"],
      "properties": { "inputSchema": { "$ref": "#/$defs/sha256" }, "outputSchema": { "$ref": "#/$defs/sha256" } }
    },
    "behavior": {
      "type": "object", "additionalProperties": false,
      "required": ["effectClass", "timeoutMs", "maxConcurrency", "requestMaxBytes", "responseMaxBytes", "rateLimit", "shutdownPolicy", "idempotencyPolicy", "compensationPolicy", "retryPolicy"],
      "properties": {
        "effectClass": { "enum": ["READ_ONLY", "IDEMPOTENT_WRITE", "NON_IDEMPOTENT_WRITE"] },
        "timeoutMs": { "type": "integer", "minimum": 100, "maximum": 60000 },
        "maxConcurrency": { "type": "integer", "minimum": 1, "maximum": 32 },
        "requestMaxBytes": { "type": "integer", "minimum": 1, "maximum": 1048576 },
        "responseMaxBytes": { "type": "integer", "minimum": 1, "maximum": 5242880 },
        "rateLimit": {
          "type": "object", "additionalProperties": false, "required": ["windowSeconds", "maxRequests"],
          "properties": {
            "windowSeconds": { "type": "integer", "minimum": 1, "maximum": 86400 },
            "maxRequests": { "type": "integer", "minimum": 1, "maximum": 100000 }
          }
        },
        "shutdownPolicy": { "enum": ["COMPLETE_IN_FLIGHT", "CANCEL_SAFE", "COMPENSATE"] },
        "idempotencyPolicy": { "type": "string", "minLength": 5, "maxLength": 500 },
        "compensationPolicy": { "type": "string", "minLength": 5, "maxLength": 1000 },
        "retryPolicy": {
          "type": "object", "additionalProperties": false, "required": ["automaticRetry"],
          "properties": { "automaticRetry": { "const": false } }
        }
      }
    },
    "testContract": {
      "type": "object", "additionalProperties": false,
      "required": ["safeInput", "expectedResult", "cleanupOrCompensation", "positiveEvidenceRef", "negativeTests", "failureScenarios", "loadProfile"],
      "properties": {
        "safeInput": { "type": "object" }, "expectedResult": { "type": "object" },
        "cleanupOrCompensation": { "type": "string", "minLength": 5, "maxLength": 1000 },
        "executionMode": { "enum": ["READ_ONLY", "SANDBOX", "COMPENSATED"] },
        "positiveEvidenceRef": { "$ref": "#/$defs/evidenceRef" },
        "negativeTests": {
          "type": "array", "minItems": 1, "maxItems": 50,
          "items": {
            "type": "object", "additionalProperties": false,
            "required": ["name", "input", "expectedErrorCode", "evidenceRef"],
            "properties": {
              "name": { "type": "string", "minLength": 3, "maxLength": 120 }, "input": { "type": "object" },
              "expectedErrorCode": { "type": "string", "minLength": 2, "maxLength": 120 }, "evidenceRef": { "$ref": "#/$defs/evidenceRef" }
            }
          }
        },
        "failureScenarios": {
          "type": "array", "minItems": 1, "maxItems": 50,
          "items": {
            "type": "object", "additionalProperties": false,
            "required": ["dependency", "expectedFailureClass", "evidenceRef"],
            "properties": {
              "dependency": { "type": "string", "minLength": 2, "maxLength": 120 },
              "expectedFailureClass": { "type": "string", "minLength": 2, "maxLength": 120 },
              "evidenceRef": { "$ref": "#/$defs/evidenceRef" }
            }
          }
        },
        "loadProfile": {
          "type": "object", "additionalProperties": false,
          "required": ["expectedConcurrency", "expectedDurationMinutes", "stressMultiplier", "stressDurationMinutes", "maxP95LatencyMs", "maxErrorRatePercent", "evidenceRef"],
          "properties": {
            "expectedConcurrency": { "type": "integer", "minimum": 1, "maximum": 32 },
            "expectedDurationMinutes": { "type": "integer", "minimum": 30, "maximum": 240 },
            "stressMultiplier": { "const": 2 },
            "stressDurationMinutes": { "type": "integer", "minimum": 10, "maximum": 120 },
            "maxP95LatencyMs": { "type": "integer", "minimum": 1, "maximum": 60000 },
            "maxErrorRatePercent": { "type": "number", "minimum": 0, "maximum": 100 },
            "evidenceRef": { "$ref": "#/$defs/evidenceRef" }
          }
        }
      }
    },
    "protocol": {
      "type": "object", "additionalProperties": false,
      "required": ["protocolVersion", "transport", "capabilities", "errorCatalog"],
      "properties": {
        "protocolVersion": { "const": "2025-11-25" }, "transport": { "const": "streamable-http" },
        "capabilities": { "type": "array", "prefixItems": [{ "const": "tools" }], "minItems": 1, "maxItems": 1 },
        "errorCatalog": { "type": "array", "minItems": 1, "maxItems": 50, "items": { "$ref": "#/$defs/errorEntry" } }
      }
    },
    "dependencies": {
      "type": "object", "additionalProperties": false,
      "required": ["runtime", "externalServices", "secretReferences", "networkPolicy"],
      "properties": {
        "runtime": {
          "type": "array", "minItems": 1, "maxItems": 50,
          "items": {
            "type": "object", "additionalProperties": false,
            "required": ["name", "version", "checksum", "evidenceRef"],
            "properties": {
              "name": { "type": "string", "minLength": 2, "maxLength": 120 },
              "version": { "type": "string", "minLength": 1, "maxLength": 120 },
              "checksum": { "$ref": "#/$defs/sha256" }, "evidenceRef": { "$ref": "#/$defs/evidenceRef" }
            }
          }
        },
        "externalServices": {
          "type": "array", "maxItems": 50,
          "items": {
            "type": "object", "additionalProperties": false,
            "required": ["name", "endpoint", "criticality", "timeoutMs", "contractRef"],
            "properties": {
              "name": { "type": "string", "minLength": 2, "maxLength": 120 },
              "endpoint": { "type": "string", "format": "uri", "pattern": "^https://" },
              "criticality": { "enum": ["OPTIONAL", "REQUIRED"] },
              "timeoutMs": { "type": "integer", "minimum": 100, "maximum": 60000 },
              "contractRef": { "$ref": "#/$defs/evidenceRef" }
            }
          }
        },
        "secretReferences": {
          "type": "array", "maxItems": 50,
          "items": {
            "type": "object", "additionalProperties": false,
            "required": ["reference", "owner", "rotationDays", "lastRotatedAt"],
            "properties": {
              "reference": { "type": "string", "pattern": "^(?:systemd-creds|vault|file)://[A-Za-z0-9._/-]+$" },
              "owner": { "$ref": "#/$defs/owner" }, "rotationDays": { "type": "integer", "minimum": 1, "maximum": 365 },
              "lastRotatedAt": { "$ref": "#/$defs/timestamp" }
            }
          }
        },
        "networkPolicy": {
          "type": "object", "additionalProperties": false,
          "required": ["outboundAllowlist", "dnsPolicy", "databaseRole", "filesystemPolicy", "evidenceRef"],
          "properties": {
            "outboundAllowlist": { "type": "array", "maxItems": 20, "items": { "type": "string", "pattern": "^[A-Za-z0-9.-]+(?::\\d+)?$" } },
            "dnsPolicy": { "const": "strict" }, "databaseRole": { "type": "string", "minLength": 2, "maxLength": 120 },
            "filesystemPolicy": { "enum": ["read-only", "isolated-runtime-only"] }, "evidenceRef": { "$ref": "#/$defs/evidenceRef" }
          }
        }
      }
    },
    "dataGovernance": {
      "type": "object", "additionalProperties": false,
      "required": ["classification", "containsPersonalData", "residencyCountries", "exportAllowed", "exportDestinations", "loggingPolicy", "redactionFields", "retentionDays", "evidenceRef"],
      "properties": {
        "classification": { "enum": ["PUBLIC", "INTERNAL", "CONFIDENTIAL", "RESTRICTED"] },
        "containsPersonalData": { "type": "boolean" },
        "residencyCountries": { "type": "array", "minItems": 1, "maxItems": 20, "items": { "type": "string", "pattern": "^[A-Z]{2}$" } },
        "exportAllowed": { "type": "boolean" },
        "exportDestinations": { "type": "array", "maxItems": 20, "items": { "type": "string", "pattern": "^[A-Z]{2}$" } },
        "loggingPolicy": { "type": "string", "minLength": 5, "maxLength": 500 },
        "redactionFields": { "type": "array", "maxItems": 50, "items": { "type": "string", "minLength": 1, "maxLength": 80 } },
        "retentionDays": { "type": "integer", "minimum": 1, "maximum": 3650 }, "evidenceRef": { "$ref": "#/$defs/evidenceRef" }
      }
    },
    "monitoringProfile": {
      "type": "object", "additionalProperties": false,
      "required": ["sloTargets", "probeIntervals", "staleAfterSeconds", "alertRules", "runbookRef", "primaryAlertChannel", "backupAlertChannel"],
      "properties": {
        "sloTargets": {
          "type": "object", "additionalProperties": false, "required": ["availabilityPercent", "p95LatencyMs", "maxErrorRatePercent"],
          "properties": {
            "availabilityPercent": { "type": "number", "minimum": 90, "maximum": 100 },
            "p95LatencyMs": { "type": "integer", "minimum": 1, "maximum": 60000 },
            "maxErrorRatePercent": { "type": "number", "minimum": 0, "maximum": 100 }
          }
        },
        "probeIntervals": {
          "type": "object", "additionalProperties": false,
          "required": ["readinessSeconds", "tlsSeconds", "routingSeconds", "oauthMcpSeconds", "syntheticCallSeconds", "integritySeconds", "dependenciesSeconds"],
          "properties": {
            "readinessSeconds": { "type": "integer", "minimum": 15, "maximum": 300 },
            "tlsSeconds": { "type": "integer", "minimum": 60, "maximum": 3600 },
            "routingSeconds": { "type": "integer", "minimum": 15, "maximum": 300 },
            "oauthMcpSeconds": { "type": "integer", "minimum": 30, "maximum": 600 },
            "syntheticCallSeconds": { "type": "integer", "minimum": 60, "maximum": 900 },
            "integritySeconds": { "type": "integer", "minimum": 60, "maximum": 900 },
            "dependenciesSeconds": { "type": "integer", "minimum": 30, "maximum": 900 }
          }
        },
        "staleAfterSeconds": { "type": "integer", "minimum": 30, "maximum": 7200 },
        "alertRules": {
          "type": "array", "minItems": 1, "maxItems": 50,
          "items": {
            "type": "object", "additionalProperties": false, "required": ["probeType", "severity", "consecutiveFailures"],
            "properties": {
              "probeType": { "type": "string", "minLength": 2, "maxLength": 120 },
              "severity": { "enum": ["WARNING", "HIGH", "CRITICAL"] },
              "consecutiveFailures": { "type": "integer", "minimum": 1, "maximum": 20 }
            }
          }
        },
        "runbookRef": { "$ref": "#/$defs/evidenceRef" }, "primaryAlertChannel": { "const": "PRIMARY_WEBHOOK" },
        "backupAlertChannel": { "const": "BACKUP_WEBHOOK" }
      }
    },
    "maintenance": {
      "type": "object", "additionalProperties": false,
      "required": ["window", "runbookRef", "rollbackRef", "recoveryTimeObjectiveMinutes", "recoveryPointObjectiveMinutes"],
      "properties": {
        "window": { "type": "string", "minLength": 5, "maxLength": 200 }, "runbookRef": { "$ref": "#/$defs/evidenceRef" },
        "rollbackRef": { "$ref": "#/$defs/evidenceRef" },
        "recoveryTimeObjectiveMinutes": { "type": "integer", "minimum": 1, "maximum": 10080 },
        "recoveryPointObjectiveMinutes": { "type": "integer", "minimum": 0, "maximum": 10080 }
      }
    },
    "autoQuarantine": {
      "type": "object", "additionalProperties": false, "required": ["enabled", "rules"],
      "properties": {
        "enabled": { "const": true },
        "rules": {
          "type": "array", "minItems": 5, "maxItems": 5, "uniqueItems": true,
          "items": { "enum": ["CROSS_HOST", "AUDIENCE_MISMATCH", "ARTIFACT_DRIFT", "CONTRACT_DRIFT", "ROUTING_DRIFT"] }
        }
      }
    },
    "errorCatalog": { "type": "array", "minItems": 1, "maxItems": 50, "items": { "$ref": "#/$defs/errorEntry" } },
    "evidence": {
      "type": "object", "additionalProperties": false,
      "required": ["architectureRef", "threatModelRef", "sastRef", "scaRef", "secretScanRef", "containerScanRef", "sbomRef", "provenanceRef", "rollbackTestRef", "compatibilityWindowEndsAt"],
      "properties": {
        "architectureRef": { "$ref": "#/$defs/evidenceRef" }, "threatModelRef": { "$ref": "#/$defs/evidenceRef" },
        "sastRef": { "$ref": "#/$defs/evidenceRef" }, "scaRef": { "$ref": "#/$defs/evidenceRef" },
        "secretScanRef": { "$ref": "#/$defs/evidenceRef" }, "containerScanRef": { "$ref": "#/$defs/evidenceRef" },
        "sbomRef": { "$ref": "#/$defs/evidenceRef" }, "provenanceRef": { "$ref": "#/$defs/evidenceRef" },
        "rollbackTestRef": { "$ref": "#/$defs/evidenceRef" }, "compatibilityWindowEndsAt": { "$ref": "#/$defs/timestamp" }
      }
    },
    "approvals": {
      "type": "object", "additionalProperties": false,
      "required": ["architecture", "security", "operations", "dataOwner", "changeManagement"],
      "properties": {
        "architecture": { "$ref": "#/$defs/approval" }, "security": { "$ref": "#/$defs/approval" },
        "operations": { "$ref": "#/$defs/approval" }, "dataOwner": { "$ref": "#/$defs/approval" },
        "changeManagement": { "$ref": "#/$defs/approval" }
      }
    },
    "change": {
      "type": "object", "additionalProperties": false,
      "required": ["changeClass", "migrationRef", "rollbackRef", "decommissionRef", "previousApprovedRevision"],
      "properties": {
        "changeClass": { "enum": ["INITIAL", "PATCH", "MINOR", "MAJOR"] },
        "migrationRef": { "$ref": "#/$defs/evidenceRef" }, "rollbackRef": { "$ref": "#/$defs/evidenceRef" },
        "decommissionRef": { "$ref": "#/$defs/evidenceRef" },
        "previousApprovedRevision": { "type": ["string", "null"], "minLength": 3, "maxLength": 80 }
      }
    }
  }
}
