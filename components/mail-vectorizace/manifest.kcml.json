                  "type": "string"
                }
              }
            }
          }
        }
      },
      "scope": "mail.metadata.read",
      "timeoutMs": 5000,
      "limits": {
        "requestMaxBytes": 4096,
        "responseMaxBytes": 262144
      }
    }
